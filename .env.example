# LiveKit credentials
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Debate agent config
DEBATE_AGENT_NAME=human-debate-agent

# Optional: Modal warmup endpoint
WARMUP_URL=

# Modal authentication (for authenticated Modal endpoints)
MODAL_API_KEY=
Modal-Key=
Modal-Secret=

# Optional: enable SDK verbose logging.
# With DEBATERHUB_VERBOSE=1 the SDK prints two layers of trace:
#   [EVENT] — one scannable line per inbound server event (elapsed time
#             + type + one-line summary). Grep these for a phase-by-phase
#             timeline of a debate.
#   [LOG]   — deeper framework chatter (raw frames, parse errors, handler
#             exceptions). Grep these when events alone aren't enough.
# Use DEBATERHUB_LOG_LEVEL=INFO|DEBUG|WARNING|ERROR for finer control.
# DEBATERHUB_VERBOSE=1
